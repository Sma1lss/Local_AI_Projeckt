[Unit]
Description=LLM Executor Service
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
WorkingDirectory=/opt/local_llm_system
EnvironmentFile=/opt/local_llm_system/.env
ExecStart=/opt/local_llm_system/.venv/bin/python -m uvicorn services.executor:app --host 0.0.0.0 --port 8004
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
