[Unit]
Description=LLM Controller Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/local_llm_system
EnvironmentFile=/opt/local_llm_system/.env
ExecStart=/opt/local_llm_system/.venv/bin/python -m uvicorn services.controller:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
